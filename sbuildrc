# https://wiki.debian.org/sbuild
# 1. Prepare
# sudo apt install sbuild mmdebstrap piuparts lintian autopkgtest
# mkdir -p ~/.cache/sbuild

# [amd64]
# mmdebstrap --include=ca-certificates --skip=output/dev --variant=buildd --include=eatmydata unstable ~/.cache/sbuild/unstable-amd64.tar.zst http://t490/ --arch amd64

# [arm64]
# mmdebstrap --include=ca-certificates --skip=output/dev --variant=buildd --include=eatmydata unstable ~/.cache/sbuild/unstable-arm64.tar.zst http://t490/ --arch arm64

# [ports]
# sudo apt install -y debian-ports-archive-keyring
# mmdebstrap --include=ca-certificates --skip=output/dev --variant=buildd --include=eatmydata unstable ~/.cache/sbuild/unstable-hppa.tar.zst http://ftp.ports.debian.org/debian-ports/ --arch hppa --include debian-ports-archive-keyring
# mmdebstrap --include=ca-certificates --skip=output/dev --variant=buildd --include=eatmydata unstable ~/.cache/sbuild/unstable-alpha.tar.zst http://ftp.ports.debian.org/debian-ports/ --arch alpha --include debian-ports-archive-keyring

# 2. Copy this config file to ~/.sbuildrc
# 3. build package
# sbuild --no-clean -c unstable-amd64 --build amd64 --arch amd64 .
$chroot_mode = 'unshare';

# mkdir -p /nvme/dot-cache/sbuild/tmp
# chmod 777 /nvme/dot-cache/sbuild/tmp
#$unshare_tmpdir_template = "$ENV{HOME}/.cache/sbuild/tmp/tmp.sbuild.XXXXXXXXXX";
if (-d "/nvme/dot-cache/sbuild/tmp") {
    $unshare_tmpdir_template = "/nvme/dot-cache/sbuild/tmp/tmp.sbuild.XXXXXXXXXX";
}

$external_commands = { "build-failed-commands" => [ [ '%SBUILD_SHELL' ] ] };

if ($distribution eq 'unstable') {
    push @{$extra_repositories}, 'deb http://t490 sid main contrib non-free non-free-firmware';
}

if ($host_arch eq 'amd64') {
    $build_environment ={
      "LD_PRELOAD" => "/usr/lib/x86_64-linux-gnu/libeatmydata.so"
    };
} elsif ($host_arch eq 'arm64') {
    $build_environment ={
      "LD_PRELOAD" => "/usr/lib/aarch64-linux-gnu/libeatmydata.so"
    };
} elsif ($host_arch eq 'hppa') {
    $build_environment ={
      "LD_PRELOAD" => "/usr/lib/hppa-linux-gnu/libeatmydata.so"
    };
}

$run_lintian = 1;
$lintian_opts = ['-E', '-v', '-i', '-I'];

$run_autopkgtest = 1;

#$run_piuparts = 1;

$purge_build_directory = 'always';

